\nomenclatureentry{a$\mathcal{D}$@[{$\mathcal{D}$}]\begingroup Full dataset of SA--AKI ICU stays\nomeqref {0}|nompageref}{ix}
\nomenclatureentry{a$\mathcal{D}_{\mathrm{train}}$@[{$\mathcal{D}_{\mathrm{train}}$}]\begingroup Training partition (80\%)\nomeqref {0}|nompageref}{ix}
