\nomenclatureentry{a$\widehat{S}_{\mathrm{KM}}(t)$@[{$\widehat{S}_{\mathrm{KM}}(t)$}]\begingroup Kaplan--Meier estimator of survival\nomeqref {0}|nompageref}{ix}
\nomenclatureentry{a$\widehat{H}_{\mathrm{NA}}(t)$@[{$\widehat{H}_{\mathrm{NA}}(t)$}]\begingroup Nelson--Aalen estimator of cumulative hazard\nomeqref {0}|nompageref}{ix}
\nomenclatureentry{a$\mathrm{HR}$@[{$\mathrm{HR}$}]\begingroup $\text{Hazard ratio } =\exp\{\beta^\top \Delta x\}$\nomeqref {0}|nompageref}{ix}
\nomenclatureentry{a$r^{\mathrm{Sch}}(t)$@[{$r^{\mathrm{Sch}}(t)$}]\begingroup $\text{Schoenfeld residual at time } t$\nomeqref {0}|nompageref}{ix}
\nomenclatureentry{a$C$@[{$C$}]\begingroup Harrell’s concordance index\nomeqref {0}|nompageref}{ix}
\nomenclatureentry{a$\mathrm{IBS}$@[{$\mathrm{IBS}$}]\begingroup Integrated Brier score over a time horizon\nomeqref {0}|nompageref}{ix}
