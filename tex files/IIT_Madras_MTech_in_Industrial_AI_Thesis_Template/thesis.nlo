\nomenclatureentry{a$\mathrm{UO}$@[{$\mathrm{UO}$}]\begingroup Urine output (mL/kg/h)\nomeqref {0}|nompageref}{ix}
\nomenclatureentry{a$\mathrm{eGFR}$@[{$\mathrm{eGFR}$}]\begingroup Estimated glomerular filtration rate\nomeqref {0}|nompageref}{ix}
\nomenclatureentry{a$\mathbb{I}\{\cdot\}$@[{$\mathbb{I}\{\cdot\}$}]\begingroup Indicator function (1 if condition holds, else 0)\nomeqref {0}|nompageref}{ix}
