\nomenclatureentry{a$\kappa:\mathbb{R}^d\to\{1,\dots,K\}\cup\{\mathrm{outlier}\}$@[{$\kappa:\mathbb{R}^d\to\{1,\dots,K\}\cup\{\mathrm{outlier}\}$}]\begingroup Clustering map (e.g., HDBSCAN)\nomeqref {0}|nompageref}{ix}
\nomenclatureentry{a$\Pi=\{C_k\}_{k=1}^{K}$@[{$\Pi=\{C_k\}_{k=1}^{K}$}]\begingroup Cluster partition of the feature space\nomeqref {0}|nompageref}{ix}
\nomenclatureentry{a$C_0$@[{$C_0$}]\begingroup Outlier set under density-based clustering\nomeqref {0}|nompageref}{ix}
\nomenclatureentry{a$d(\cdot,\cdot)$@[{$d(\cdot,\cdot)$}]\begingroup Distance metric (e.g., Euclidean in embedding space)\nomeqref {0}|nompageref}{ix}
\nomenclatureentry{a$\mu_k$@[{$\mu_k$}]\begingroup $\text{Cluster representative/centroid for cluster } C_k$\nomeqref {0}|nompageref}{ix}
\nomenclatureentry{a$s$@[{$s$}]\begingroup Silhouette coefficient\nomeqref {0}|nompageref}{ix}
\nomenclatureentry{a$\phi_j(x)$@[{$\phi_j(x)$}]\begingroup $\text{SHAP attribution of feature } j \text{ for case } x$\nomeqref {0}|nompageref}{ix}
\nomenclatureentry{a$g(x)$@[{$g(x)$}]\begingroup $\text{Additive explanation for prediction at } x\text{, } g(x)=\phi_0 + \sum_{j=1}^{p}\phi_j(x)$\nomeqref {0}|nompageref}{ix}
